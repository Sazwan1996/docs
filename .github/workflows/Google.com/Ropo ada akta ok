### `scripts/sync-github.js` – GitHub Stats

```javascript
// scripts/sync-github.js
const fs = require('fs');
const path = require('path');
const axios = require('axios');

const DATA_DIR = path.join(__dirname, '../data');
const USERNAMES = ['Sazwanismail', 'Sazwanend', 'Sazwan96'];
const GITHUB_TOKEN = process.env.GH_TOKEN || '';

async function fetchGitHubData(username) {
    const headers = GITHUB_TOKEN ? { Authorization: `Bearer ${GITHUB_TOKEN}` } : {};
    try {
        const { data: user } = await axios.get(`https://api.github.com/users/${username}`, { headers });
        const { data: repos } = await axios.get(`https://api.github.com/users/${username}/repos?per_page=100&sort=updated`, { headers });
        return {
            username,
            name: user.name || username,
            public_repos: user.public_repos,
            followers: user.followers,
            following: user.following,
            created_at: user.created_at,
            updated_at: user.updated_at,
            repos: repos.map(r => ({ name: r.name, description: r.description, language: r.language, stars: r.stargazers_count, forks: r.forks_count, url: r.html_url, updated_at: r.updated_at }))
        };
    } catch (error) {
        console.error(`❌ Error fetching GitHub for ${username}:`, error.message);
        return { username, error: true };
    }
}

async function main() {
    if (!fs.existsSync(DATA_DIR)) fs.mkdirSync(DATA_DIR, { recursive: true });
    const results = await Promise.all(USERNAMES.map(fetchGitHubData));
    fs.writeFileSync(path.join(DATA_DIR, 'github.json'), JSON.stringify(results, null, 2));
    console.log('✅ GitHub data saved.');
}

main();
```

